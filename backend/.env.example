# Backend environment variables (desarrollo local)
DATABASE_URL=postgresql+psycopg://plagaia:plagaia@localhost:5432/plagaia_db
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
APP_NAME=AgroPlaga AI
REGISTRATION_MODE=open

# CORS (solo relevante para web-panel en navegador)
# CORS_ORIGINS=http://localhost:5173
# CORS_ORIGIN_REGEX=none

# Optional admin bootstrap user
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production
ADMIN_NAME=Admin
