# Dominio público del piloto (variable API_DOMAIN en deploy/pilot.env)
{$API_DOMAIN} {
	encode gzip

	# Panel web B2B (React estático)
	redir /panel /panel/ permanent
	handle_path /panel/* {
		root * /srv/panel
		try_files {path} /index.html
		file_server
	}

	# API FastAPI
	handle /api/* {
		reverse_proxy backend:8000
	}

	handle /docs* {
		reverse_proxy backend:8000
	}

	handle /openapi.json {
		reverse_proxy backend:8000
	}

	# Landing pública (raíz del dominio)
	handle {
		root * /srv/landing
		try_files {path} /index.html
		file_server
	}
}
