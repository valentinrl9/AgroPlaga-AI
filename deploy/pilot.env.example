# Copiar a deploy/pilot.env y rellenar antes del despliegue:
#   cp deploy/pilot.env.example deploy/pilot.env

# --- Dominio (obligatorio) ---
# Registro DNS tipo A: api.tudominio.com → IP del VPS
API_DOMAIN=api.tudominio.com

# --- PostgreSQL (generar contraseñas largas) ---
POSTGRES_USER=plagaia
POSTGRES_PASSWORD=cambiar-por-secreto-largo
POSTGRES_DB=plagaia_db

# --- JWT / app ---
SECRET_KEY=cambiar-por-secreto-largo-minimo-32-caracteres
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Admin inicial (cámbialo tras el primer login) ---
ADMIN_EMAIL=admin@agroplaga.local
ADMIN_PASSWORD=cambiar-admin-piloto
ADMIN_NAME=Admin Piloto

# --- Piloto Lean: registro cerrado ---
REGISTRATION_MODE=invite_only
PILOT_SEED_INVITES=true

# --- Usuario maestro demo (entrevistas; upsert al arrancar backend) ---
# MASTER_EMAIL=tu@email.com
# MASTER_PASSWORD=contraseña-demo
# MASTER_NAME=Tu Nombre

# --- CORS (opcional; panel en /panel del mismo dominio no lo necesita) ---
